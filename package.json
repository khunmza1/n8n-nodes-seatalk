{
    "name": "n8n-nodes-seatalk",
    "version": "1.0.0",
    "description": "Custom n8n nodes for SeaTalk Open Platform",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "license": "MIT",
    "homepage": "https://open.seatalk.io/",
    "keywords": [
        "n8n-community-node-package"
    ],
    "author": {
        "name": "Sorawith",
        "email": ""
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/sorawith/n8n-nodes-seatalk.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
  "nodes": [
    "dist/nodes/SeaTalk/SeaTalk.node.js",
    "dist/nodes/SeaTalk/SeaTalkTrigger.node.js"
  ],
  "credentials": [
    "dist/credentials/SeaTalkApi.credentials.js"
  ]
},
    "devDependencies": {
        "@n8n/node-cli": "*",
        "eslint": "9.39.4",
        "prettier": "3.8.1",
        "release-it": "19.2.4",
        "typescript": "5.9.3"
    },
    "peerDependencies": {
        "n8n-workflow": "*"
    }
}